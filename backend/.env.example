# =============================================================================
# Autonomous Disaster Response & Resource Coordinator
# Backend Environment Configuration
# Copy this file to .env and fill in your values before running the application
# =============================================================================

# --- Application ---
APP_ENV=development
# Options: development | production | test
LOG_LEVEL=INFO
# Options: DEBUG | INFO | WARNING | ERROR | CRITICAL

# --- Database ---
DATABASE_URL=sqlite:///./disaster_response.db
# For a persistent path: sqlite:////absolute/path/to/disaster_response.db

# --- LLM (required for LangGraph agent reasoning nodes) ---
OPENAI_API_KEY=sk-proj-your-openai-api-key-here
# Get your key at: https://platform.openai.com/api-keys
# Model used: gpt-4o-mini (cost-efficient for hackathon)

# --- External Data APIs (optional) ---
# If either key is absent or blank, the system falls back to mock_data.py
GDACS_API_URL=https://www.gdacs.org/xml/rss.xml
OPENWEATHER_API_KEY=
# Get a free key at: https://openweathermap.org/api

# --- CORS ---
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
# Comma-separated list of allowed frontend origins

# --- WebSocket ---
WS_HEARTBEAT_INTERVAL=30
# Seconds between server-sent ping frames to keep connections alive

# --- Scheduler ---
SCHEDULER_INTERVAL_SECONDS=60
# How often (seconds) the LangGraph pipeline runs automatically
# Set to 0 to disable automatic scheduling (manual /agents/run only)
